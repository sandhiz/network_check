# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=netwatch_db
DB_PORT=3306

# Ping Engine
DEFAULT_PING_INTERVAL=60
PING_TIMEOUT=5000
MAX_CONCURRENT_PINGS=50
SCHEDULER_TICK_SECONDS=5

# Log Retention
LOG_RETENTION_DAYS=90

# Discord Notification
DISCORD_WEBHOOK_ENABLED=false
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_TIMEOUT=5000
DISCORD_NOTIFICATION_COOLDOWN_SECONDS=10